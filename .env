# Flask 应用配置
SECRET_KEY=your-secret-key-change-in-production

# 服务器URL配置 - 用于二维码生成
# 设置为你的外网IP或域名，这样微信扫码才能正确访问
SERVER_URL=http://localhost:5000

# 域名配置
# 用户端域名
USER_DOMAIN=device.carbit.com.cn
# 后台管理域名
ADMIN_DOMAIN=admin.device.carbit.com.cn

# 数据库配置
# 数据库类型: sqlite 或 mysql
DB_TYPE=mysql

# MySQL配置 (当DB_TYPE=mysql时使用)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=carbit2014
MYSQL_DATABASE=device_management

